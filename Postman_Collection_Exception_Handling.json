{
  "info": {
    "name": "Multi-Tenant SaaS Backend - Complete API Collection",
    "description": "Complete Postman collection for testing the Multi-Tenant SaaS Backend with Exception Handling & Transaction Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tenant1.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Order Management",
      "item": [
        {
          "name": "Create Order (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "productId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "quantity",
                  "value": "2",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/orders?productId=1&quantity=2",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                {
                  "key": "productId",
                  "value": "1"
                },
                {
                  "key": "quantity",
                  "value": "2"
                }
              ]
            }
          },
          "description": "Creates an order successfully (quantity <= 5)"
        },
        {
          "name": "Create Order (Rollback Demo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "productId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "quantity",
                  "value": "10",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/orders?productId=1&quantity=10",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                {
                  "key": "productId",
                  "value": "1"
                },
                {
                  "key": "quantity",
                  "value": "10"
                }
              ]
            }
          },
          "description": "Triggers rollback demonstration (quantity > 5)"
        },
        {
          "name": "Create Order (Product Not Found)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "productId",
                  "value": "999",
                  "type": "text"
                },
                {
                  "key": "quantity",
                  "value": "2",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/orders?productId=999&quantity=2",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                {
                  "key": "productId",
                  "value": "999"
                },
                {
                  "key": "quantity",
                  "value": "2"
                }
              ]
            }
          },
          "description": "Tests ResourceNotFoundException"
        }
      ]
    },
    {
      "name": "Error Testing",
      "item": [
        {
          "name": "Test General Exception",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/nonexistent-endpoint",
              "host": ["{{baseUrl}}"],
              "path": ["nonexistent-endpoint"]
            }
          },
          "description": "Tests 404 error handling"
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global pre-request script",
          "console.log('Executing request: ' + pm.info.requestName);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test script",
          "pm.test('Response time is less than 3000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});"
        ]
      }
    }
  ]
}
